# REQUIRED: GitHub Personal Access Token for MCP GitHub server
GITHUB_PERSONAL_ACCESS_TOKEN=your_github_pat_here

# REQUIRED: ElevenLabs API key for voice sidecar
# Get your key from: https://elevenlabs.io/app/developers/api-keys
# Free tier includes 10,000 characters/month
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# REQUIRED: Supabase access token for MCP Supabase server
# Get your token from: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# REQUIRED: Google Stitch API key for the Stitch MCP server
# Configure this if you enable the Stitch server in mcp.config.json
STITCH_API_KEY=your_stitch_api_key_here

# Optional: Reverse-engineering MCP child servers (disabled by default in mcp.config.json)
# Provide these paths if you want EVOKORE to proxy ghidra-headless-mcp, ReVa, or binary-mcp.
# GHIDRA_INSTALL_DIR=C:\path\to\ghidra
# EVOKORE_RE_GHIDRA_HEADLESS_PYTHON=C:\path\to\ghidra-headless-mcp\.venv\Scripts\python.exe
# EVOKORE_RE_GHIDRA_HEADLESS_REPO=C:\path\to\ghidra-headless-mcp
# EVOKORE_RE_REVA_PYTHON=C:\path\to\reverse-engineering-assistant\.venv\Scripts\python.exe
# EVOKORE_RE_REVA_REPO=C:\path\to\reverse-engineering-assistant
# EVOKORE_RE_BINARY_MCP_PYTHON=C:\path\to\binary-mcp\.venv\Scripts\python.exe
# EVOKORE_RE_BINARY_MCP_REPO=C:\path\to\binary-mcp
# WINDBG_PATH=C:\path\to\windbg\amd64
# X64DBG_BRIDGE_URL=http://127.0.0.1:8765

# OPTIONAL: Not currently consumed by EVOKORE-MCP, reserved for future integrations
# OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Override path to mcp.config.json (default: project root)
# EVOKORE_MCP_CONFIG_PATH=./mcp.config.json

# Optional: Override EVOKORE runtime home directory (default: ~/.evokore).
# Session manifests, replay logs, evidence logs, and cache files all live
# under this directory. Used by src/SessionManifest.ts and the hook scripts.
# EVOKORE_HOME=~/.evokore

# Optional: Enable tenant-scoped session directory layout (default: disabled).
# When set to "true", session files are namespaced under
# ~/.evokore/tenants/{tenantId}/sessions/ where tenantId is sourced from the
# OAuth JWT `sub` claim. When unset, the legacy flat layout is used.
# EVOKORE_TENANT_SCOPING=true

# Optional: Tool discovery mode. Default: dynamic (v3.1+).
#
# When unset (or set to "dynamic"), tools/list returns the always-visible
# native tools plus only the proxied tools the current session has activated
# via discover_tools. This produces a lean ~1.5-2.5K-token payload instead of
# the legacy 12-31K-token full proxied tool dump.
#
# Operators who depend on the pre-v3.1 behavior (every proxied tool ships in
# the initial tools/list) can set the safety pin below to restore it. The
# safety pin also overrides any EVOKORE_DISCOVERY_PROFILE selection.
# EVOKORE_TOOL_DISCOVERY_MODE=legacy
#
# Optional: Discovery profile name (default: built-in "default" — every
# native tool always visible). Selects a profile defined under
# discovery.profiles in mcp.config.json. EVOKORE_TOOL_DISCOVERY_MODE=legacy
# is a hard safety pin and overrides this.
#
# Five preset profiles are shipped in mcp.config.json:
#   coding         - file ops, git, testing, native code skills (<= ~8K tokens)
#   research       - read/search heavy: memory, docs, navigation (<= ~5K)
#   voice          - voice sidecar + minimal control surface (<= ~3K)
#   legacy-full    - deprecation shim: every native + proxy tool visible
#   legacy-dynamic - v3.0 default: native always visible, proxy dynamic
# See docs/TOOL_DISCOVERY_PROFILES.md for measured token counts and tradeoffs.
# EVOKORE_DISCOVERY_PROFILE=coding
# Optional: tools/list cursor pagination. Off by default to preserve
# pre-v3.1 behavior. Enables automatically when the client sends a
# cursor param. Set EVOKORE_TOOL_LIST_PAGINATION=on to force pagination
# even when the first call has no cursor (useful for capped clients
# like Cursor IDE that silently truncate at 40 tools).
# Default page size 35 keeps the first page under the Cursor IDE
# 40-tool cap. Clamped to [1, 1000].
# EVOKORE_TOOL_LIST_PAGINATION=on
# EVOKORE_TOOL_LIST_PAGE_SIZE=35


# Optional: Enable filesystem watcher for auto-refreshing the skill index (default: disabled)
# EVOKORE_SKILL_WATCHER=true

# Optional: Voice Sidecar port (default: 8888)
# VOICE_SIDECAR_PORT=8888

# Optional: Maximum concurrent voice sidecar WebSocket clients (default: 5)
# VOICE_SIDECAR_MAX_CONNECTIONS=5

# Optional: Disable voice sidecar audio playback (set to 1)
# VOICE_SIDECAR_DISABLE_PLAYBACK=

# Optional: Directory for voice sidecar audio artifacts
# VOICE_SIDECAR_ARTIFACT_DIR=

# Optional: Timeout (ms) for child server boot during proxy bootstrap (default: 15000)
# EVOKORE_CHILD_SERVER_BOOT_TIMEOUT_MS=15000

# Optional: Timeout for proxied tool call requests in ms (default: 60000)
# EVOKORE_PROXY_REQUEST_TIMEOUT_MS=60000

# Optional: Role-based access control (RBAC) role name (default: none = flat permissions)
# Available roles defined in permissions.yml: admin, developer, readonly
# EVOKORE_ROLE=developer

# Optional: Deny unknown tools by default (secure posture � enable for production hardening)
# When unset or false, unknown tools default to allow (backward compatible)
# EVOKORE_SECURITY_DEFAULT_DENY=true

# Optional: Start EVOKORE in HTTP server mode instead of stdio (default: false)
# EVOKORE_HTTP_MODE=true

# Optional: Port for HTTP server mode (default: 3100)
# EVOKORE_HTTP_PORT=3100

# Optional: Host/interface for HTTP server mode (default: 127.0.0.1)
# EVOKORE_HTTP_HOST=127.0.0.1

# Optional: Session TTL in milliseconds for multi-tenant HTTP sessions (default: 3600000 = 1 hour)
# EVOKORE_SESSION_TTL_MS=3600000

# Optional: Session store backend for HTTP mode (default: file). Options: file, memory, redis
# EVOKORE_SESSION_STORE=file

# Optional: Redis connection URL for redis session store (default: redis://127.0.0.1:6379)
# EVOKORE_REDIS_URL=redis://127.0.0.1:6379

# Optional: Redis key namespace prefix for session keys (default: evokore)
# EVOKORE_REDIS_KEY_PREFIX=evokore

# Optional: Enable webhook event notifications to external systems (default: false)
# Configure webhook URLs in mcp.config.json under the webhooks key
# EVOKORE_WEBHOOKS_ENABLED=true

# Allow webhooks to private/loopback addresses (local dev only � NEVER enable in production)
# EVOKORE_WEBHOOKS_ALLOW_PRIVATE=true

# Allow httpGet() to fetch from private/loopback addresses (local dev only -- NEVER enable in production)
# EVOKORE_HTTP_ALLOW_PRIVATE=true

# Optional: Custom plugins directory (default: plugins/ relative to project root)
# EVOKORE_PLUGINS_DIR=./plugins

# Optional: Enable STT (speech-to-text) in VoiceSidecar (default: false)
# EVOKORE_STT_ENABLED=true

# Optional: STT provider selection (default: whisper-api). Options: whisper-api, local-whisper, local
# EVOKORE_STT_PROVIDER=whisper-api

# Optional: Whisper API model (default: whisper-1)
# EVOKORE_STT_MODEL=whisper-1

# Optional: Local whisper CLI model (default: base). Options: tiny, base, small, medium, large
# EVOKORE_STT_LOCAL_MODEL=base

# Optional: Path to local whisper CLI binary (default: whisper)
# EVOKORE_WHISPER_PATH=whisper

# Optional: TTS provider for VoiceSidecar (default: elevenlabs). Options: elevenlabs, openai-compat
# EVOKORE_TTS_PROVIDER=elevenlabs

# Optional: Base URL for OpenAI-compatible TTS endpoint (default: http://127.0.0.1:8880)
# Used when EVOKORE_TTS_PROVIDER=openai-compat (e.g., Kokoro-FastAPI, Chatterbox TTS API)
# EVOKORE_TTS_BASE_URL=http://127.0.0.1:8880

# Optional: API key for OpenAI-compatible TTS endpoint (not required for local servers)
# EVOKORE_TTS_API_KEY=

# Optional: Default voice name for OpenAI-compatible TTS (default: nova)
# EVOKORE_TTS_VOICE=nova

# Optional: Default model for OpenAI-compatible TTS (default: tts-1)
# EVOKORE_TTS_MODEL=tts-1

# Optional: Enable local-only usage telemetry (default: false)
# Collects only aggregate metrics: tool call counts, error rates, session counts, latency
# No PII is collected. Metrics stored at ~/.evokore/telemetry/metrics.json
# When EVOKORE_HTTP_MODE=true, GET /metrics exposes the same aggregate counters in Prometheus text format
# If EVOKORE_AUTH_REQUIRED=true, scrape /metrics with Authorization: Bearer <token>
# EVOKORE_TELEMETRY=true

# Optional: Override the telemetry directory (default: ~/.evokore/telemetry)
# Used by tests for isolation; normal operators should leave this unset.
# EVOKORE_TELEMETRY_DIR=/path/to/custom/telemetry

# Optional: Enable external telemetry export (requires EVOKORE_TELEMETRY=true)
# EVOKORE_TELEMETRY_EXPORT=true

# Optional: HTTP(S) URL to POST telemetry metrics to (required when export is enabled)
# EVOKORE_TELEMETRY_EXPORT_URL=https://example.com/v1/metrics

# Optional: Export interval in milliseconds (default: 60000, minimum: 10000)
# EVOKORE_TELEMETRY_EXPORT_INTERVAL_MS=60000

# Optional: HMAC-SHA256 signing secret for telemetry export (optional)
# EVOKORE_TELEMETRY_EXPORT_SECRET=your-secret

# Optional: Auto-sync Claude memory files when session stops (default: true)
# Set to false to disable automatic memory sync at session-wrap boundary
# EVOKORE_AUTO_MEMORY_SYNC=true

# Optional: Bearer token for dashboard authentication (omit for local-only mode)
# When set, all dashboard API routes require Authorization: Bearer <token>
# EVOKORE_DASHBOARD_TOKEN=

# Optional: Dashboard RBAC role (default: admin for local-only, readonly for token mode)
# Available roles: admin, developer, readonly
# EVOKORE_DASHBOARD_ROLE=admin

# Optional: Explicit approvals WebSocket endpoint for the dashboard approvals page.
# Use this when the dashboard runs on a different host/port or origin than the EVOKORE HTTP server.
# When unset, loopback dashboards auto-target :EVOKORE_HTTP_PORT on the current hostname;
# non-loopback dashboards fall back to same-origin /ws/approvals unless EVOKORE_HTTP_HOST is set.
# EVOKORE_DASHBOARD_APPROVAL_WS_URL=ws://127.0.0.1:3100/ws/approvals

# Optional: Dedicated bearer token for the approvals WebSocket endpoint.
# When unset, the approvals page falls back to the dashboard session token.
# EVOKORE_DASHBOARD_APPROVAL_WS_TOKEN=

# Optional: Enable WebSocket real-time approval events on HttpServer (default: false)
# When enabled, the /ws/approvals WebSocket endpoint streams approval lifecycle events
# EVOKORE_WS_APPROVALS_ENABLED=true

# Optional: WebSocket heartbeat interval in milliseconds (default: 30000)
# EVOKORE_WS_HEARTBEAT_MS=30000

# Optional: Maximum concurrent WebSocket approval clients (default: 10)
# EVOKORE_WS_MAX_CLIENTS=10

# Deprecated: allow WS auth via ?token= query string (default: false, prefer Authorization header)
# EVOKORE_WS_ALLOW_QUERY_TOKEN=true

# Optional: Structured audit logging to ~/.evokore/audit/ (enabled by default, set to false to disable)
# Records security and operational events as JSONL for operator review
# EVOKORE_AUDIT_LOG=false

# Optional: Enable external audit event export (requires audit log enabled, which is the default)
# EVOKORE_AUDIT_EXPORT=true

# Optional: HTTP(S) URL to POST audit events to (required when export is enabled)
# EVOKORE_AUDIT_EXPORT_URL=https://example.com/v1/audit

# Optional: Export interval in milliseconds (default: 60000, minimum: 10000)
# EVOKORE_AUDIT_EXPORT_INTERVAL_MS=60000

# Optional: Maximum number of audit entries per export batch (default: 100)
# EVOKORE_AUDIT_EXPORT_BATCH_SIZE=100

# Optional: HMAC-SHA256 signing secret for audit export (optional)
# EVOKORE_AUDIT_EXPORT_SECRET=your-secret

# Optional: Skill execution sandbox mode (default: auto)
# 'container' = always use Docker/Podman, 'process' = subprocess only, 'auto' = try container then fallback
# EVOKORE_SANDBOX_MODE=auto

# Optional: Container sandbox memory limit in MB (default: 256)
# EVOKORE_SANDBOX_MEMORY_MB=256

# Optional: Container sandbox CPU limit (default: 1)
# EVOKORE_SANDBOX_CPU_LIMIT=1

# Optional: Warm missing container sandbox images at startup to reduce first-run latency (default: false)
# EVOKORE_SANDBOX_PREPULL=true

# Optional: Custom seccomp profile JSON file for container sandbox executions.
# When unset, Docker/Podman runtime defaults apply.
# EVOKORE_SANDBOX_SECCOMP_PROFILE=./path/to/seccomp-profile.json

# Optional: Per-language container sandbox memory overrides in MB.
# When unset, the global EVOKORE_SANDBOX_MEMORY_MB baseline is used.
# EVOKORE_SANDBOX_BASH_MEMORY_MB=128
# EVOKORE_SANDBOX_JAVASCRIPT_MEMORY_MB=256
# EVOKORE_SANDBOX_TYPESCRIPT_MEMORY_MB=384
# EVOKORE_SANDBOX_PYTHON_MEMORY_MB=512

# Optional: Per-language container sandbox CPU overrides.
# When unset, the global EVOKORE_SANDBOX_CPU_LIMIT baseline is used.
# EVOKORE_SANDBOX_BASH_CPU_LIMIT=0.5
# EVOKORE_SANDBOX_JAVASCRIPT_CPU_LIMIT=1
# EVOKORE_SANDBOX_TYPESCRIPT_CPU_LIMIT=1
# EVOKORE_SANDBOX_PYTHON_CPU_LIMIT=1

# Optional: Disable purpose-gate keyword-triggered worker auto-dispatch (default: enabled).
# EVOKORE_WORKER_AUTODISPATCH=false

# Optional: Disable background worker intervals (claims janitor, DLQ). Default: true.
# EVOKORE_WORKERS_ENABLED=false

# Optional: Session identifier for the TrustLedger and worker-context env propagation.
# EVOKORE_SESSION_ID=default

# Optional: Active steering mode for ComplianceChecker (dev|research|review|debug|security-audit). Default: dev
# EVOKORE_STEERING_MODE=dev

# Optional: Tool-list schema-deferred mode. Default: full.
# When set to "deferred", tools/list responses ship each tool with a
# placeholder inputSchema and _meta: { schema_deferred: true }; clients
# must call describe_tool to fetch full schemas. Only enable when you
# have personally verified the client tolerates placeholder schemas and
# implements the describe_tool bootstrap path.
# EVOKORE_TOOL_SCHEMA_MODE=full

# Optional: Compat-probe fallback window in milliseconds for deferred
# mode. If no client calls describe_tool within this
# window after the first tools/list response, the runtime reverts to
# full mode and emits a one-time stderr warning. Default: 60000.
# EVOKORE_TOOL_SCHEMA_FALLBACK_MS=60000

# Optional: Override the path to the skill composition graph artifact
# (defaults to <repo-root>/skill-graph.json, generated by 'npm run skill-graph')
# EVOKORE_SKILL_GRAPH_PATH=/path/to/skill-graph.json

# Fix 1: TillDone hook non-blocking options (autonomous-friendly).
# The Stop hook (scripts/hooks/tilldone.js) historically exited with
# code 2 to block session stop whenever incomplete tasks remained.
# That is correct for human-driven sessions but stalls long-running
# autonomous loops that never explicitly clear their task list. These
# three env vars relax the block; defaults preserve legacy behaviour.

# Optional: TillDone Stop-hook mode.
#   block (default) — exit 2 when incomplete tasks remain (legacy)
#   warn            — print the warning, allow stop (exit 0)
#   off             — skip the incomplete check entirely (allow stop)
# EVOKORE_TILLDONE_MODE=block

# Optional: in 'block' mode, allow stop after N consecutive identical
# blocks. Counter at ~/.evokore/sessions/{sessionId}-tilldone-blocks.json
# resets when the tasks file is touched (the agent edited tasks).
# Set to a positive integer; unset/zero disables the escape valve.
# EVOKORE_TILLDONE_MAX_BLOCKS=3

# Optional: in 'block' mode, allow stop if the tasks file has not been
# modified for more than this many milliseconds. Lets a stalled
# autonomous loop exit cleanly. Unset/zero disables this escape valve.
# EVOKORE_TILLDONE_IDLE_TIMEOUT_MS=600000

# Optional: Protection profile preset that coordinates the runtime-protection
# knobs (TillDone Stop hook, repo-audit hook). Per-knob env vars always win.
# Recognized values:
#   strict / balanced — historic blocking behavior (no overrides)
#   autonomous       — TillDone block-mode plus max_blocks=3 + idle_timeout=10min
#                      so autonomous loops cannot deadlock on stale tasks
#   relaxed          — TillDone in warn mode (allow stop, surface incomplete tasks)
#   off              — TillDone in off mode + repo-audit hook disabled
# Damage-control is NOT part of the profile and always stays on.
# Default: unset (legacy behavior, identical to the strict preset).
# EVOKORE_PROTECTION_PROFILE=strict

# Optional: Enable the anti-slop PostToolUse hook (warning-only).
# Detects wasteful tool-call patterns (re-reading after edit, 3+
# consecutive reads of the same path, bash echo/printf for plain
# communication) and emits one stderr advisory per pattern per session.
# The hook always exits 0 — never blocks — so autonomous loops are
# preserved by construction. Disabled by default. See SKILLS/EVOKORE
# EXTENSIONS/anti-slop/SKILL.md for the heuristic definitions and
# the matching skill body.
# EVOKORE_ANTISLOP_HOOK=true

# ----------------------------------------------------------------------------
# Damage-control argv-aware guardrail overrides (DC-33..DC-43).
#
# These env vars opt INTO normally-blocked operations. Each is unset by
# default; setting the literal string "true" bypasses the corresponding
# rule for the current process. Any other value (including "1", "yes")
# leaves the rule active.
# ----------------------------------------------------------------------------

# Allow autonomous "gh issue create" (DC-41).
# When unset, autonomous issue filing is blocked so skill auto-chains
# (e.g., to-prd -> to-issues -> triage-bug) cannot file GitHub issues
# without operator confirmation. Read-only ops (gh issue list/view/comment
# /close) are always allowed.
# EVOKORE_AUTO_FILE_ISSUES=true

# Allow "gh pr create" from inside an agent worktree (DC-42).
# When unset, gh pr create is blocked when the cwd matches
# */.claude/worktrees/* so throwaway worktrees and panel-of-experts
# agents cannot autonomously file PRs. PR creation from the repo root
# remains allowed (PR Template workflow).
# EVOKORE_AUTO_FILE_PRS=true

# Allow "gh issue|pr edit --add-label <sensitive>" (DC-43).
# Sensitive labels: security, release, ready-for-agent. Adding any of
# these labels triggers downstream automation (release pipelines, agent
# pickup queues, security review routing); the default-deny ensures the
# operator confirms intent. --remove-label is never gated.
# EVOKORE_AUTO_LABEL_ISSUES=true

# Allow "git gc --prune=now" (DC-39).
# When unset, explicit gc --prune=now is blocked because it removes
# unreachable refs immediately, which can destroy the last-resort
# recovery window. "git gc --auto" (implicit maintenance) is always
# allowed.
# EVOKORE_ALLOW_GC_PRUNE=true

# f runtime guards 
# tools/list_changed debounce window in milliseconds. Coalesces rapid
# notifications (discover_tools, execute_skill nextSteps activation,
# skill watcher refreshes). 0 disables debounce. Clamped to [0, 5000].
# Default: 250.
# EVOKORE_TOOLS_LIST_CHANGED_DEBOUNCE_MS=250

# Maximum concurrent in-flight fleet_spawn operations. Spawns past the
# cap queue FIFO and drain on fleet_release. Clamped to [1, 50].
# Default: 5.
# EVOKORE_PANEL_MAX_CONCURRENCY=5

# Block nextSteps[] auto-activation of destructive skills (tdd,
# pr-manager, orch-refactor, to-issues, release-readiness) until the
# active session has a passing verification-quality evidence row.
# Set to 0/false/off/no to disable. Default: on.
# EVOKORE_AUTO_ACTIVATION_REQUIRE_TRUTH_SCORE=on

# Tail-window size when scanning the active session evidence log for
# verification-quality rows. Bounded to [1, 1000]. Default: 50.
# EVOKORE_TRUTH_SCORE_EVIDENCE_WINDOW=50

# Numeric truth-score threshold when no passed:true field is present.
# Rows with a numeric score field >= threshold satisfy the gate.
# Default: 0.7.
# EVOKORE_TRUTH_SCORE_THRESHOLD=0.7
