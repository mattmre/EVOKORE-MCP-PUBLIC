          "github_list_issues",
          "github_get_file_contents",
          "github_push_files",
          "github_create_branch"
        ]
      },
      "research": {
        "description": "Read/search-heavy workflows: memory, docs, navigation, registry, and lightweight read-only file ops.",
        "mandatoryInjectionSkills": [
          "release-readiness",
          "repo-ingestor",
          "docs-architect",
          "orch-review",
          "orch-plan",
          "tool-governance",
          "orch-refactor"
        ],
        "alwaysVisible": [
          "discover_tools",
