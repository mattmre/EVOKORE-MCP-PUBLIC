          "github_search_issues"
        ]
      },
      "voice": {
        "description": "Voice sidecar workflows: ElevenLabs MCP tools plus a minimal control surface (discovery + skill resolution).",
        "mandatoryInjectionSkills": [
          "release-readiness",
          "repo-ingestor",
          "docs-architect",
          "orch-review",
          "orch-plan",
          "tool-governance",
          "orch-refactor"
        ],
        "alwaysVisible": [
          "discover_tools",
          "resolve_workflow",
          "search_skills",
          "get_skill_help",
          "proxy_server_status",
          "elevenlabs_text_to_speech",
          "elevenlabs_speech_to_text",
          "elevenlabs_text_to_voice",
          "elevenlabs_voice_clone",
          "elevenlabs_get_voice",
          "elevenlabs_search_voices",
          "elevenlabs_search_voice_library",
          "elevenlabs_isolate_audio",
          "elevenlabs_play_audio",
          "elevenlabs_make_outbound_call",
          "elevenlabs_create_agent",
          "elevenlabs_get_agent",
          "elevenlabs_list_agents",
          "elevenlabs_get_conversation",
          "elevenlabs_list_conversations"
        ]
      },
      "legacy-full": {
        "description": "Pre-v3.1 deprecation shim: every native AND every proxy tool ships in the initial tools/list. High token cost; prefer named profiles where possible.",
        "alwaysVisible": "all"
      },
      "legacy-dynamic": {
        "description": "v3.0 dynamic-mode default: every native tool is always visible; proxy tools are dynamically activated via discover_tools. No tier filtering beyond native/proxy.",
        "alwaysVisible": "all-native"
      }
    }
  },
  "servers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "fs": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"]
    },
    "elevenlabs": {
      "disabled": true,
      "_comment": "disabled by default — requires ELEVENLABS_API_KEY env var. Re-enable once the API key is in your environment (and the optional dep `uvx` / elevenlabs-mcp is installed).",
      "command": "uvx",
      "args": ["elevenlabs-mcp"],
      "env": {
        "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
        "ELEVENLABS_MCP_OUTPUT_MODE": "both"
      }
    },
    "supabase": {
      "disabled": true,
      "_comment": "disabled by default — requires SUPABASE_ACCESS_TOKEN env var. Re-enable once the token is in your environment.",
      "command": "npx",
      "args": ["-y", "@supabase/mcp-server-supabase", "--read-only"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${SUPABASE_ACCESS_TOKEN}"
      }
    },
    "stitch": {
      "disabled": true,
      "_comment": "disabled by default — requires STITCH_API_KEY and confirmation that the upstream `@google/stitch-mcp` package is published. Re-enable only after both are confirmed.",
      "command": "npx",
      "args": ["-y", "@google/stitch-mcp"],
      "env": {
        "STITCH_API_KEY": "${STITCH_API_KEY}"
      }
    },
    "ghidra_headless": {
      "disabled": true,
      "command": "${EVOKORE_RE_GHIDRA_HEADLESS_PYTHON}",
      "args": ["-m", "ghidra_headless_mcp", "--ghidra-install-dir", "${GHIDRA_INSTALL_DIR}"],
      "cwd": "${EVOKORE_RE_GHIDRA_HEADLESS_REPO}"
    },
    "reva": {
      "disabled": true,
      "command": "${EVOKORE_RE_REVA_PYTHON}",
      "args": ["-m", "reva_cli"],
      "cwd": "${EVOKORE_RE_REVA_REPO}"
    },
    "binary_analysis": {
      "disabled": true,
      "command": "${EVOKORE_RE_BINARY_MCP_PYTHON}",
      "args": ["-m", "src.server"],
      "cwd": "${EVOKORE_RE_BINARY_MCP_REPO}",
      "env": {
        "GHIDRA_HOME": "${GHIDRA_INSTALL_DIR}",
        "WINDBG_PATH": "${WINDBG_PATH}",
        "X64DBG_BRIDGE_URL": "${X64DBG_BRIDGE_URL}"
      }
    }
  }
}
