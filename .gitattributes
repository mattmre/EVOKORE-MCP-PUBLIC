# Enforce LF line endings on all text files cross-platform.
# Prevents CRLF drift from Windows clones.

* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.md        text eol=lf
*.markdown  text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf
*.sh        text eol=lf
*.py        text eol=lf

# Config
.gitignore       text eol=lf
.gitattributes   text eol=lf
.eslintrc        text eol=lf
.editorconfig    text eol=lf
.env.example     text eol=lf

# Binary — never normalize
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.zip   binary
*.gz    binary
*.tar   binary
*.wav   binary
*.mp3   binary
*.mp4   binary
*.mov   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.eot   binary
